{
  "name": "mcp-home",
  "version": "0.2.6",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:http": "tsx src/index-http.ts",
    "dev:stdio": "tsx src/index-stdio.ts",
    "refresh:host": "powershell -ExecutionPolicy Bypass -File scripts/refresh-windows-host.ps1",
    "schedule:host-refresh": "powershell -ExecutionPolicy Bypass -File scripts/install-host-refresh-task.ps1",
    "unschedule:host-refresh": "powershell -ExecutionPolicy Bypass -File scripts/remove-host-refresh-task.ps1",
    "test:anthropic:mcp": "tsx scripts/test-anthropic-mcp.ts",
    "test:openai:mcp": "tsx scripts/test-openai-mcp.ts",
    "smoke:http": "tsx scripts/smoke-http.ts",
    "start:http": "node dist/index-http.js",
    "start:stdio": "node dist/index-stdio.js",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
